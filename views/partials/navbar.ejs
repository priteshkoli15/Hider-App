<style>

    .custom-navbar {

        background-color: rgba(23, 26, 33, 0.88);

        border: 1px solid var(--border-color);

        border-radius: 20px;

        padding: 0.9rem 1.1rem;

        backdrop-filter: blur(10px);

        -webkit-backdrop-filter: blur(10px);

        box-shadow:
            0 10px 30px rgba(0, 0, 0, 0.25);

        margin-bottom: 2rem;

    }

    .navbar-brand {

        color: var(--text-primary) !important;

        font-size: 1.1rem;

        font-weight: 700;

        letter-spacing: -0.03em;

        display: flex;

        align-items: center;

        gap: 0.7rem;

    }

    .brand-icon {

        width: 42px;
        height: 42px;

        border-radius: 14px;

        background-color:
            rgba(79, 140, 255, 0.12);

        border:
            1px solid rgba(79, 140, 255, 0.22);

        display: flex;

        align-items: center;

        justify-content: center;

        color: var(--accent-primary);

        font-weight: 800;

        font-size: 1rem;

    }

    .nav-actions {

        display: flex;

        align-items: center;

        gap: 0.75rem;

        flex-wrap: wrap;

    }

    .nav-btn {

        border-radius: 14px !important;

        padding: 0.7rem 1rem;

        font-size: 0.92rem;

        font-weight: 600;

        transition: var(--transition);

        border: 1px solid transparent;

    }

    .nav-btn-outline {

        background-color: transparent;

        border-color: var(--border-color);

        color: var(--text-primary);

    }

    .nav-btn-outline:hover {

        background-color: var(--bg-secondary);

        border-color: var(--accent-primary);

        color: var(--text-primary);

        transform: translateY(-1px);

    }

    .nav-btn-primary {

        background-color: var(--accent-primary);

        color: white;

    }

    .nav-btn-primary:hover {

        background-color: var(--accent-hover);

        color: white;

        transform: translateY(-1px);

    }

    .nav-btn-success {

        background-color: var(--success-color);

        color: white;

    }

    .nav-btn-success:hover {

        opacity: 0.92;

        color: white;

        transform: translateY(-1px);

    }

    .nav-btn-danger {

        background-color: var(--danger-color);

        color: white;

    }

    .nav-btn-danger:hover {

        opacity: 0.92;

        color: white;

        transform: translateY(-1px);

    }

    .nav-btn-dashboard {

        background-color: #F59E0B;

        color: #111827;

    }

    .nav-btn-dashboard:hover {

        background-color: #E58B00;

        color: #111827;

        transform: translateY(-1px);

    }

    .nav-btn-vault {

        background-color: #0EA5E9;

        color: white;

    }

    .nav-btn-vault:hover {

        background-color: #0284C7;

        color: white;

        transform: translateY(-1px);

    }

    @media (max-width: 768px) {

        .custom-navbar {

            padding: 1rem;

        }

        .container-fluid {

            flex-direction: column;

            align-items: flex-start !important;

            gap: 1rem;

        }

        .nav-actions {

            width: 100%;

        }

        .nav-btn {

            width: 100%;

            text-align: center;

        }

    }

</style>

<nav class="navbar custom-navbar">

    <div class="container-fluid p-0">

        <a class="navbar-brand" href="/">

            <div class="brand-icon">
                L
            </div>

            Locker Vault

        </a>

        <div class="nav-actions">

            <a
                class="btn nav-btn nav-btn-outline"
                href="/datas"
            >
                Home
            </a>

            <a
                class="btn nav-btn nav-btn-outline"
                href="/datas/new"
            >
                Anonymous Mode
            </a>

            <% if(!locals.currentUser){ %>

                <a
                    class="btn nav-btn nav-btn-success"
                    href="/signup"
                >
                    Sign Up
                </a>

                <a
                    class="btn nav-btn nav-btn-primary"
                    href="/login"
                >
                    Login
                </a>

            <% } else { %>

                <a
                    class="btn nav-btn nav-btn-dashboard"
                    href="/dashboard"
                >
                    Dashboard
                </a>

                <a
                    class="btn nav-btn nav-btn-vault"
                    href="/vault/new"
                >
                    New Vault
                </a>

                <a
                    class="btn nav-btn nav-btn-danger"
                    href="/logout"
                >
                    Logout
                </a>

            <% } %>

        </div>

    </div>

</nav>