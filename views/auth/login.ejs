<%- include("../partials/head.ejs") %>
<%- include("../partials/navbar.ejs") %>
<%- include("../partials/flash.ejs") %>

<style>

    .auth-wrapper {

        min-height: calc(100vh - 180px);

        display: flex;

        align-items: center;

        justify-content: center;

        padding: 2rem 1rem;

    }

    .auth-card {

        width: 100%;

        max-width: 460px;

        padding: 2.7rem;

    }

    .auth-badge {

        width: 62px;
        height: 62px;

        margin: 0 auto 1.6rem;

        border-radius: 18px;

        background:
            rgba(79, 140, 255, 0.10);

        border:
            1px solid rgba(79, 140, 255, 0.20);

        display: flex;

        align-items: center;

        justify-content: center;

        color: var(--accent-primary);

        font-size: 1.35rem;

        font-weight: 800;

    }

    .auth-title {

        text-align: center;

        font-size: 2rem;

        margin-bottom: 0.6rem;

    }

    .auth-subtitle {

        text-align: center;

        color: var(--text-secondary);

        margin-bottom: 2.2rem;

        font-size: 0.96rem;

    }

    .auth-btn {

        width: 100%;

        padding: 0.95rem;

        margin-top: 0.5rem;

    }

    .auth-footer-text {

        text-align: center;

        color: var(--text-secondary);

        margin-bottom: 1rem;

        font-size: 0.92rem;

    }

    .auth-secondary-btn {

        width: 100%;

        padding: 0.9rem;

    }

    @media (max-width: 576px) {

        .auth-card {

            padding: 2rem 1.3rem;

            border-radius: 18px;

        }

        .auth-title {

            font-size: 1.7rem;

        }

    }

</style>

<div class="auth-wrapper">

    <div class="vault-card auth-card">

        <div class="auth-badge">
            L
        </div>

        <h1 class="auth-title">
            Secure Login
        </h1>

        <p class="auth-subtitle">
            Access your private vault securely and manage your hidden data safely.
        </p>

        <form action="/login" method="POST">

            <div class="mb-4">

                <label class="form-label">
                    Email Address
                </label>

                <input
                    type="email"
                    name="email"
                    placeholder="Enter your email"
                    class="form-control"
                    required
                >

            </div>

            <div class="mb-4">

                <label class="form-label">
                    Password
                </label>

                <input
                    id="loginPassword"
                    type="password"
                    name="password"
                    placeholder="Enter your password"
                    class="form-control"
                    required
                >
                <div class="form-check mt-2">
                    <input type="checkbox" id="showPassword"
                    class="form-check-input"
                    >
                    <label for="showPassword" class="form-check-label">
                        Show Password
                    </label>
                </div>

            </div>

            <button class="btn btn-primary auth-btn">
                Login to Vault
            </button>

        </form>

        <hr>

        <p class="auth-footer-text">
            Don’t have an account yet?
        </p>

        <a
            href="/signup"
            class="btn btn-outline-light auth-secondary-btn"
        >
            Create New Account
        </a>

    </div>

</div>

<script>

    const passwordInput =
        document.getElementById("loginPassword");

    const showPassword =
        document.getElementById("showPassword");

    showPassword.addEventListener("change", () => {

        if(showPassword.checked){
            passwordInput.type = "text";
        }
        else{
            passwordInput.type = "password";
        }

    });

</script>

<%- include("../partials/footer.ejs") %>