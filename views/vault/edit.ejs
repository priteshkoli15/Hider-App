<%- include("../partials/head.ejs") %>
<%- include("../partials/navbar.ejs") %>
<%- include("../partials/flash.ejs") %>
<style>

    .vault-edit-wrapper {

        min-height: calc(100vh - 180px);

        display: flex;

        align-items: center;

        justify-content: center;

        padding: 2rem 1rem;

    }

    .vault-edit-card {

        width: 100%;

        max-width: 780px;

        padding: 2.8rem;

    }

    .vault-edit-badge {

        width: 64px;
        height: 64px;

        border-radius: 18px;

        background:
            rgba(79, 140, 255, 0.10);

        border:
            1px solid rgba(79, 140, 255, 0.20);

        display: flex;

        align-items: center;

        justify-content: center;

        color: var(--accent-primary);

        font-size: 1.35rem;

        font-weight: 800;

        margin-bottom: 1.6rem;

    }

    .vault-edit-title {

        font-size: 2.1rem;

        margin-bottom: 0.7rem;

        line-height: 1.15;

    }

    .vault-edit-subtitle {

        color: var(--text-secondary);

        line-height: 1.8;

        margin-bottom: 2.4rem;

        max-width: 620px;

    }

    .secret-textarea {

        min-height: 280px;

        resize: vertical;

        line-height: 1.9;

        font-size: 0.96rem;

    }

    .password-note {

        margin-top: 0.7rem;

        color: var(--text-secondary);

        font-size: 0.88rem;

        line-height: 1.7;

    }

    .vault-actions {

        display: flex;

        gap: 1rem;

        flex-wrap: wrap;

        margin-top: 2rem;

    }

    .vault-actions .btn {

        min-width: 180px;

        padding:
            0.95rem 1.5rem;

        font-weight: 600;

    }

    .delete-section {

        margin-top: 3rem;

        padding-top: 2rem;

        border-top:
            1px solid var(--border-color);

    }

    .delete-warning {

        color: var(--text-secondary);

        line-height: 1.8;

        margin-bottom: 1.3rem;

        max-width: 620px;

    }

    .delete-btn {

        background-color: var(--danger-color);

        border: none;

        padding:
            0.95rem 1.5rem;

        font-weight: 600;

        min-width: 220px;

    }

    .delete-btn:hover {

        background-color: #dc2626;

    }

    .security-box {

        margin-top: 2.5rem;

        padding: 1.4rem 1.5rem;

        border-radius: 18px;

        background:
            rgba(79, 140, 255, 0.06);

        border:
            1px solid rgba(79, 140, 255, 0.12);

    }

    .security-box h6 {

        margin-bottom: 0.7rem;

    }

    .security-box p {

        margin-bottom: 0;

        color: var(--text-secondary);

        line-height: 1.8;

        font-size: 0.92rem;

    }

    @media (max-width: 768px) {

        .vault-edit-card {

            padding: 2rem 1.4rem;

        }

        .vault-edit-title {

            font-size: 1.8rem;

        }

    }

    @media (max-width: 576px) {

        .vault-actions {

            flex-direction: column;

        }

        .vault-actions .btn {

            width: 100%;

        }

        .delete-btn {

            width: 100%;

        }

    }

</style>

<div class="vault-edit-wrapper">

    <div class="vault-card vault-edit-card">

        <div class="vault-edit-badge">
            E
        </div>

        <h1 class="vault-edit-title">
            Edit Your Secret
        </h1>

        <p class="vault-edit-subtitle">

            Modify your private vault data securely. You can
            also optionally replace the current protection password.

        </p>

        <form
            action="/vault/<%= data._id %>?_method=PATCH"
            method="POST"
        >

        <div class="mb-3">
            <label for="title" class="form-label">
                Secret Title
            </label>
            <input type="text"
            id="title"
            name="title"
            class="form-control"
            maxlength="100"
            required
            value="<%= data.title || ''%>"
            >
        </div>

            <div class="mb-4">

                <label class="form-label">
                    Secret Data
                </label>

                <textarea
                    id="hiddenData"
                    name="hiddenData"
                    class="form-control secret-textarea"
                    required
                ><%= data.hiddenData %></textarea>
                <p id="charCount"></p>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    New Password
                </label>

                <input
                    id="secretPassword"
                    type="password"
                    name="pass"
                    class="form-control"
                    placeholder="Enter new password (optional)"
                >
                <div class="form-check mt-2">
                    <input type="checkbox" id="showPassword"
                    class="form-check-input"
                    >
                    <label for="showPassword" class="form-check-label">
                        Show Password
                    </label>
                </div>

                <p class="password-note">

                    Leave this field empty if you do not want
                    to change the current password.

                </p>

            </div>

            <div class="vault-actions">

                <button class="btn btn-primary">
                    Update Secret
                </button>

                <a
                    href="/dashboard"
                    class="btn btn-outline-light"
                >
                    Back to Dashboard
                </a>

            </div>

        </form>

        <div class="security-box">

            <h6>
                Secure Editing
            </h6>

            <p>

                Your changes are applied instantly after updating.
                Double-check sensitive information before saving.

            </p>

        </div>

        <div class="delete-section">

            <h4 class="mb-3">
                Delete Secret
            </h4>

            <p class="delete-warning">

                Deleting this secret is permanent and cannot
                be undone later. Make sure you really want
                to remove this hidden data from your vault.

            </p>

            <form
                action="/vault/<%= data._id %>?_method=DELETE"
                method="POST"
            >

                <button
                    class="btn delete-btn"
                    onclick="return confirm('Delete this secret?')"
                >
                    Delete Secret Permanently
                </button>

            </form>

        </div>

    </div>

</div>

<script> 
const textarea = document.getElementById("hiddenData");
const counter = document.getElementById("charCount");

function updateCounter() {
    const length = textarea.value.length;

    counter.textContent = `${length} / 5000 characters`;

    if(length >= 4500){
        counter.style.color = "red";
    } else {
        counter.style.color = "";
    }
}

textarea.addEventListener("input", updateCounter);
updateCounter();

const passwordInput = document.getElementById("secretPassword");
const showPassword = document.getElementById("showPassword");

showPassword.addEventListener("change", ()=> {
    if(showPassword.checked){
        passwordInput.type = "text";
    } else {
        passwordInput.type = "password";
    }
});
</script>

<%- include("../partials/footer.ejs") %>