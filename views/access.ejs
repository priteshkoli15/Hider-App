<%- include("partials/head.ejs") %>
<%- include("partials/navbar.ejs") %>
<%- include("partials/flash.ejs") %>

<style>

    .access-wrapper {

        min-height: calc(100vh - 180px);

        display: flex;

        align-items: center;

        justify-content: center;

        padding: 2rem 1rem;

    }

    .access-card {

        width: 100%;

        max-width: 850px;

        padding: 2.8rem;

    }

    .access-header {

        display: flex;

        align-items: center;

        justify-content: space-between;

        gap: 1rem;

        margin-bottom: 2rem;

        flex-wrap: wrap;

    }

    .access-badge {

        width: 64px;
        height: 64px;

        border-radius: 18px;

        background:
            rgba(79, 140, 255, 0.10);

        border:
            1px solid rgba(79, 140, 255, 0.20);

        display: flex;

        align-items: center;

        justify-content: center;

        color: var(--accent-primary);

        font-size: 1.3rem;

        font-weight: 800;

    }

    .access-title {

        font-size: 2rem;

        margin-bottom: 0.45rem;

    }

    .access-subtitle {

        color: var(--text-secondary);

        margin-bottom: 0;

        line-height: 1.7;

    }

    .data-section {

        margin-top: 2rem;

    }

    .section-label {

        display: block;

        color: var(--text-secondary);

        font-size: 0.9rem;

        margin-bottom: 0.7rem;

        text-transform: uppercase;

        letter-spacing: 0.08em;

    }

    .secret-id-box {

        background-color: var(--secondary-bg);

        border: 1px solid var(--border-color);

        border-radius: 16px;

        padding: 1rem 1.2rem;

        font-family: monospace;

        font-size: 1rem;

        color: var(--text-primary);

        word-break: break-all;

    }

    .secret-content {

        background-color: var(--secondary-bg);

        border: 1px solid var(--border-color);

        border-radius: 18px;

        padding: 1.5rem;

        min-height: 220px;

        line-height: 1.9;

        color: var(--text-primary);

        white-space: pre-wrap;

        overflow-wrap: break-word;

    }

    .action-grid {

        display: flex;

        gap: 1rem;

        flex-wrap: wrap;

        margin-top: 2.5rem;

    }

    .action-grid form {

        flex: 1;

        min-width: 180px;

    }

    .action-grid .btn {

        width: 100%;

        padding: 0.95rem 1rem;

        font-weight: 600;

    }

    .delete-btn {

        background-color: var(--danger-color);

        border: none;

    }

    .delete-btn:hover {

        background-color: #dc2626;

    }

    .privacy-note {

        margin-top: 2.5rem;

        padding: 1.3rem 1.5rem;

        border-radius: 18px;

        background:
            rgba(79, 140, 255, 0.06);

        border:
            1px solid rgba(79, 140, 255, 0.12);

    }

    .privacy-note h6 {

        margin-bottom: 0.7rem;

    }

    .privacy-note p {

        margin-bottom: 0;

        color: var(--text-secondary);

        line-height: 1.8;

        font-size: 0.92rem;

    }

    @media (max-width: 768px) {

        .access-card {

            padding: 2rem 1.4rem;

        }

        .access-title {

            font-size: 1.7rem;

        }

    }

    @media (max-width: 576px) {

        .action-grid {

            flex-direction: column;

        }

        .action-grid form {

            width: 100%;

        }

    }

</style>

<div class="access-wrapper">

    <div class="vault-card access-card">

        <div class="access-header">

            <div>

                <div class="access-badge">
                    S
                </div>

            </div>

            <div class="flex-grow-1">

                <h1 class="access-title">
                    Secret Data Accessed
                </h1>

                <p class="access-subtitle">

                    Your hidden information has been securely
                    retrieved using the secret ID and password.

                </p>

            </div>

        </div>

        <div class="data-section">

            <label class="section-label">
                Secret ID
            </label>

            <div class="secret-id-box">
                <%= newData.dataId %>
            </div>

        </div>
          <!-- time  feature -->
    <div class="data-section">

        <label class="section-label">
            Created
        </label>
        <div class="secret-id-box">
            <%= newData.createdAt ? newData.createdAt.toLocaleDateString() : "Unknown" %>
        </div>
    </div>

    <div class="data-section">
        <label class="section-label">
            Last Updated
        </label>
        <div class="secret-id-box">
          <%= newData.updatedAt ? newData.updatedAt.toLocaleDateString() : "Unknown" %>
        </div>

    </div>
        
        <div class="data-section">

            <h2 class="mb-3">
                <%= newData.title %>
            </h2>

            <label class="section-label">
                Hidden Data
            </label>

            <div class="secret-content">
                <%= newData.hiddenData %>
            </div>

        </div>

        <div class="action-grid">

            <form
                action="/datas/<%= newData._id %>/edit"
                method="get"
            >

                <button class="btn btn-primary">
                    Edit Secret
                </button>

            </form>

            <form
                action="/datas/<%= newData._id %>?_method=DELETE"
                method="post"
            >

                <button class="btn delete-btn">
                    Delete Secret
                </button>

            </form>

            <form action="/datas">

                <button class="btn btn-outline-light">
                    Back to Home
                </button>

            </form>

        </div>

        <div class="privacy-note">

            <h6>
                Security Reminder
            </h6>

            <p>

                Anyone with both the secret ID and password
                can access this hidden data. Keep your credentials
                secure and avoid sharing them publicly.

            </p>

        </div>

    </div>

</div>

<%- include("partials/footer.ejs") %>