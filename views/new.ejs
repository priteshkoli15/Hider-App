<%- include("partials/head.ejs") %>
<%- include("partials/navbar.ejs") %>
<%- include("partials/flash.ejs") %>

<style>

    .create-wrapper {

        min-height: calc(100vh - 180px);

        display: flex;

        align-items: center;

        justify-content: center;

        padding: 2rem 1rem;

    }

    .create-card {

        width: 100%;

        max-width: 760px;

        padding: 2.8rem;

    }

    .create-badge {

        width: 64px;
        height: 64px;

        border-radius: 18px;

        background:
            rgba(79, 140, 255, 0.10);

        border:
            1px solid rgba(79, 140, 255, 0.20);

        display: flex;

        align-items: center;

        justify-content: center;

        color: var(--accent-primary);

        font-size: 1.4rem;

        font-weight: 800;

        margin-bottom: 1.6rem;

    }

    .create-title {

        font-size: 2.2rem;

        margin-bottom: 0.7rem;

        line-height: 1.15;

    }

    .create-subtitle {

        color: var(--text-secondary);

        margin-bottom: 2.5rem;

        line-height: 1.8;

        max-width: 620px;

    }

    .secret-textarea {

        min-height: 260px;

        resize: vertical;

        line-height: 1.8;

        font-size: 0.96rem;

    }

    .password-note {

        color: var(--text-secondary);

        font-size: 0.88rem;

        margin-top: 0.7rem;

        line-height: 1.7;

    }

    .create-actions {

        display: flex;

        gap: 1rem;

        margin-top: 2rem;

        flex-wrap: wrap;

    }

    .create-btn {

        padding:
            0.95rem 1.5rem;

        min-width: 180px;

    }

    .privacy-box {

        margin-top: 2.5rem;

        padding: 1.3rem 1.5rem;

        border-radius: 18px;

        background:
            rgba(79, 140, 255, 0.06);

        border:
            1px solid rgba(79, 140, 255, 0.12);

    }

    .privacy-box h6 {

        margin-bottom: 0.7rem;

        font-size: 1rem;

    }

    .privacy-box p {

        margin-bottom: 0;

        font-size: 0.92rem;

        line-height: 1.8;

    }

    @media (max-width: 768px) {

        .create-card {

            padding: 2rem 1.4rem;

        }

        .create-title {

            font-size: 1.8rem;

        }

    }

    @media (max-width: 576px) {

        .create-actions {

            flex-direction: column;

        }

        .create-btn {

            width: 100%;

        }

    }

</style>

<div class="create-wrapper">

    <div class="vault-card create-card">

        <div class="create-badge">
            +
        </div>

        <h1 class="create-title">
            Create Anonymous Secret
        </h1>

        <p class="create-subtitle">

            Store hidden information securely without creating
            an account. Your secret can later be accessed
            manually using its generated ID and password.

        </p>

        <form action="/datas" method="post">
            <div class="form-group">
                <label for="title" class="form-label">
                    Secret Title
                </label>

                <input type="text"
                id="title"
                name="title"
                maxlength="100"
                required
                class="form-control"
                placeholder="e.g. Netflix account details">
            </div>

            <div class="mb-4">

                <label class="form-label">
                    Hidden Secret Data
                </label>

                <textarea
                    name="hiddenData"
                    class="form-control secret-textarea"
                    placeholder="Write your hidden data here..."
                    required
                ></textarea>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Secret Password
                </label>

                <input
                    id="secretPassword"
                    type="text"
                    name="pass"
                    placeholder="Create access password"
                    class="form-control"
                    required
                >
                <div class="form-check mt-2">
                    <input type="checkbox" id="showPassword"
                    class="form-check-input"
                    >
                    <label for="showPassword" class="form-check-label">
                        Show Password
                    </label>
                </div>

                <p class="password-note">

                    This password will be required along with
                    your secret ID to access the hidden data later.

                </p>

            </div>

            <div class="create-actions">

                <button
                    class="btn btn-primary create-btn"
                >
                    Create Secret
                </button>

                <a
                    href="/datas"
                    class="btn btn-outline-light create-btn"
                >
                    Back to Home
                </a>

            </div>

        </form>

        <div class="privacy-box">

            <h6>
                Privacy Reminder
            </h6>

            <p>

                Keep your generated secret ID and password safe.
                Without both credentials, the hidden data cannot
                be accessed again.

            </p>

        </div>

    </div>

</div>

<script>
    const passwordInput = document.getElementById("secretPassword");
    const showPassword = document.getElementById("showPassword");

    showPassword.addEventListener("change", ()=> {
    if(showPassword.checked){
        passwordInput.type = "text";
    } else {
        passwordInput.type = "password";
    }
});
</script>

